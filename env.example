# =============================================
# ML Feature Store Pipeline — ENV CONFIG
# =============================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ----- Feast -----
FEAST_REPO_PATH=./feature_store/feast_repo
FEAST_PROVIDER=local

# ----- Redis (Online Feature Store) -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ----- Airflow -----
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW_PORT=8080

# ----- MLflow (Experiment Tracking) -----
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=feature_store_pipeline

# ----- Data -----
DATA_SOURCE_PATH=./data/raw/sample_dataset.csv
PROCESSED_DATA_PATH=./data/processed/features.parquet
FEATURE_LOOKBACK_DAYS=30

# ----- Model -----
MODEL_OUTPUT_PATH=./model/artifacts/model.pkl
MODEL_EVAL_THRESHOLD=0.80

# ----- Pipeline -----
PIPELINE_SCHEDULE_INTERVAL=@daily
RETRAINING_SCHEDULE_INTERVAL=@weekly
